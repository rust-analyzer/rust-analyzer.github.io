&lt;/div&gt;
&lt;/div&gt;
&lt;div class=&quot;sect1&quot;&gt;
&lt;h2 id=&quot;internal-improvements&quot;&gt;&lt;a class=&quot;anchor&quot; href=&quot;#internal-improvements&quot;&gt;&lt;/a&gt;Internal Improvements&lt;/h2&gt;
&lt;div class=&quot;sectionbody&quot;&gt;
&lt;div class=&quot;ulist&quot;&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;&lt;a href=&quot;https://github.com/rust-analyzer/rust-analyzer/pull/18485&quot;&gt;&lt;code&gt;#18485&lt;/code&gt;&lt;/a&gt; migrate &lt;code&gt;add_braces&lt;/code&gt; assist to use &lt;code&gt;SyntaxFactory&lt;/code&gt;.&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;a href=&quot;https://github.com/rust-analyzer/rust-analyzer/pull/18521&quot;&gt;&lt;code&gt;#18521&lt;/code&gt;&lt;/a&gt; migrate &lt;code&gt;reorder_impl_items&lt;/code&gt; assist to use &lt;code&gt;SyntaxFactory&lt;/code&gt;.&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;a href=&quot;https://github.com/rust-analyzer/rust-analyzer/pull/18552&quot;&gt;&lt;code&gt;#18552&lt;/code&gt;&lt;/a&gt; fix formatting in &quot;missing &lt;code&gt;rust-src&lt;/code&gt;&quot; message.&lt;/p&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;</description>
      </item>
    
      <item>
